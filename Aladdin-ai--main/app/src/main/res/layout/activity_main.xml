<?xml version="1.0" encoding="utf-8"?>
<!--
  Phase 2 – activity_main.xml
  Root layout for MainActivity. A single FrameLayout hosts the Compose/Fragment
  container.  Real UI is rendered via Jetpack Compose in ChatScreen.kt.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coordinator_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Primary compose container -->
    <FrameLayout
        android:id="@+id/compose_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!--
      Phase 2 feature overlay: partial-transcript floating chip
      Shown via Compose AnimatedVisibility; this view is GONE by default
      so Fragment-based flows can use it directly if needed.
    -->
    <com.google.android.material.chip.Chip
        android:id="@+id/partial_transcript_chip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_margin="16dp"
        android:visibility="gone"
        android:text=""
        android:maxWidth="320dp"
        android:ellipsize="end"
        android:maxLines="1"
        app:chipIcon="@android:drawable/ic_btn_speak_now"
        app:chipIconVisible="true"
        app:layout_anchor="@id/compose_container"
        app:layout_anchorGravity="bottom|center_horizontal" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
