# ============================================================
# Aladdin — Environment Variables Template  (Feature 8)
# Copy this file to .env and fill in values as needed.
# Lines starting with # are comments.
# ============================================================

# ── Multilingual TTS Model Paths ─────────────────────────────
# Piper binary
PIPER_BINARY=models/piper/piper

# English TTS (Piper — always available)
TTS_EN_MODEL=models/piper/en_US-lessac-medium.onnx
TTS_EN_CONFIG=models/piper/en_US-lessac-medium.onnx.json

# Hindi TTS (Piper — download via scripts/download_models_multilingual.sh)
TTS_HI_MODEL=models/piper/hi_IN-hindi_male-medium.onnx
TTS_HI_CONFIG=models/piper/hi_IN-hindi_male-medium.onnx.json

# Gujarati TTS (Piper — download via scripts/download_models_multilingual.sh)
TTS_GU_MODEL=models/piper/gu_IN-cmu_indic-medium.onnx
TTS_GU_CONFIG=models/piper/gu_IN-cmu_indic-medium.onnx.json

# ── STT Model Paths ──────────────────────────────────────────
STT_HI_MODEL=models/vosk/vosk-model-hi-0.22
STT_GU_MODEL=models/vosk/vosk-model-gu-0.42
STT_EN_MODEL=models/vosk/vosk-model-small-en-us-0.15

# ── Whisper Settings ─────────────────────────────────────────
# Model size: tiny | base | small | medium | large
WHISPER_MODEL=base
# Device: cpu | cuda
WHISPER_DEVICE=cpu
# Auto-detect language (leave empty for auto, or set "hi"/"gu"/"en")
WHISPER_LANGUAGE=

# ── Ollama LLM ───────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
# Recommended multilingual models: llama3.1 | qwen2.5 | gemma3
OLLAMA_MODEL=llama3.1
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=512
OLLAMA_TIMEOUT=300

# ── Google Cloud TTS (Gujarati fallback) ─────────────────────
# Only required if Piper Gujarati voice is unavailable.
# Get credentials at: https://console.cloud.google.com/
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_TTS_ENABLED=false

# ── Microsoft Azure TTS (optional secondary fallback) ────────
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_TTS_ENABLED=false

# ── ElevenLabs TTS (optional premium fallback) ───────────────
ELEVENLABS_API_KEY=
ELEVENLABS_TTS_ENABLED=false
ELEVENLABS_HI_VOICE_ID=
ELEVENLABS_GU_VOICE_ID=
ELEVENLABS_EN_VOICE_ID=

# ── Default Language ─────────────────────────────────────────
DEFAULT_LANGUAGE=en

# ── Language Detection Settings ──────────────────────────────
LANG_DETECTION_THRESHOLD=0.55
LANG_HISTORY_WINDOW=5
LANG_HISTORY_WEIGHT=0.2

# ── TTS Preloading ───────────────────────────────────────────
TTS_PRELOAD_ON_STARTUP=true
TTS_STREAMING_ENABLED=true

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/aladdin.log

# ── Telegram Bot (optional) ──────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
