# Aladdin AI Backend — Environment Variables
# Copy this file to .env and fill in your keys

# ── LLM Provider Keys ─────────────────────────────────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ── Default Provider / Model ──────────────────────────────────────────────────
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_LLM_MODEL=llama3.1
OLLAMA_HOST=http://localhost:11434

# ── STT (Whisper) ─────────────────────────────────────────────────────────────
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# ── TTS ───────────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM
PIPER_BINARY=piper
PIPER_MODEL_PATH=

# ── Wake Word ─────────────────────────────────────────────────────────────────
WAKE_WORDS=aladdin,hey aladdin
PICOVOICE_ACCESS_KEY=
OWW_MODEL_PATHS=

# ── Session / Context ─────────────────────────────────────────────────────────
SESSION_TIMEOUT=3600
MAX_CONTEXT_TOKENS=4096
MAX_RETRIES=3

# ── Tool System ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
IMAP_HOST=imap.gmail.com
IMAP_USER=
IMAP_PASS=

# ── Browser Automation ────────────────────────────────────────────────────────
BROWSER_HEADLESS=true

# ── Calendar ─────────────────────────────────────────────────────────────────
GOOGLE_CREDENTIALS_PATH=data/google_credentials.json

# ── Web Search ────────────────────────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
NEWSAPI_KEY=
